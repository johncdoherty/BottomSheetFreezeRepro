<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BottomSheetFreezeRepro.DemoPage2"
             Title="Demo 2">

    <VerticalStackLayout
        Padding="16"
        Spacing="12"
        VerticalOptions="Center"
        HorizontalOptions="Center">
        
        <Label
            FontSize="24"
            FontAttributes="Bold"
            Text="Demo Page 2"
            HorizontalOptions="Center" />
        
        <Label
            FontSize="16"
            Text="This is another demo page for testing"
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center" />
        
        <BoxView
            Color="LightGreen"
            HeightRequest="100"
            WidthRequest="100"
            CornerRadius="10"
            Margin="20" />
        
    </VerticalStackLayout>

</ContentPage>
