<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:BottomSheetFreezeRepro.ViewModels"
    x:Class="BottomSheetFreezeRepro.ContentViews.ReproFeatureIdentifyContentView"
    x:Name="featureIdentifyContentView"
    x:DataType="viewmodel:MainViewModel"
    SafeAreaEdges="Container, Container, Container, SoftInput">
    
    <!-- Parent Grid to hold both scenarios -->
    <Grid>
        <!-- BROKEN SCENARIO - No height constraint, will freeze when dragged -->
        <Grid
        Padding="0"
        BackgroundColor="Transparent"
        HorizontalOptions="Fill"
        RowDefinitions="Auto,Auto,Auto,*"
        VerticalOptions="Fill"
        IsVisible="{Binding ShowWorkaround, Converter={StaticResource InvertedBoolConverter}}">
        <HorizontalStackLayout
            Grid.Row="0"
            HorizontalOptions="Center"
            Margin="0,10,0,10">
            <Label
                Text="🔴 BROKEN: Will Freeze on iOS"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="#DC3545" />
        </HorizontalStackLayout>

        <VerticalStackLayout
            Grid.Row="1"
            Margin="10,0,10,10"
            Spacing="5">
            <Label
                Text="ISSUE:"
                FontAttributes="Bold" />
            <Label
                Text="✗ Filter section has no height constraint" />
            <Label
                Text="✗ Content extends into tab bar zone" />
            <Label
                Text="✗ Bottom sheet FREEZES when dragging" />
            <Label
                Text=""
                Margin="0,10,0,0" />
            <Label
                Text="Drag the sheet down slowly - it will FREEZE when the grabber handle reaches the tab bar zone"
                FontAttributes="Italic"
                FontSize="12" />
        </VerticalStackLayout>

        <Border
            Grid.Row="2"
            Margin="10,5,10,10"
            Padding="10"
            StrokeThickness="1"
            Stroke="LightGray"
            BackgroundColor="#F8F9FA">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        Text="Filter Options"
                        FontSize="16"
                        FontAttributes="Bold"
                        VerticalOptions="Center" />
                    <Button
                        Grid.Column="1"
                        Text="✕"
                        FontSize="20"
                        BackgroundColor="Transparent"
                        Padding="0"
                        HeightRequest="40"
                        WidthRequest="40" />
                </Grid>

                <FlexLayout
                    Wrap="Wrap"
                    Direction="Row"
                    JustifyContent="Start"
                    AlignItems="Start">
                    <Button Text="Filter 1" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#DC3545" TextColor="White" />
                    <Button Text="Filter 2" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#DC3545" TextColor="White" />
                    <Button Text="Filter 3" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#DC3545" TextColor="White" />
                    <Button Text="Filter 4" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#DC3545" TextColor="White" />
                    <Button Text="Filter 5" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#DC3545" TextColor="White" />
                    <Button Text="Filter 6" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#DC3545" TextColor="White" />
                    <Button Text="Filter 7" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#DC3545" TextColor="White" />
                    <Button Text="Filter 8" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#DC3545" TextColor="White" />
                </FlexLayout>

                <Button
                    Text="Clear All"
                    FontSize="12"
                    Padding="8,4"
                    Margin="0,10,0,0"
                    BackgroundColor="Transparent"
                    TextColor="#DC3545"
                    BorderColor="#DC3545"
                    BorderWidth="1"
                    CornerRadius="12"
                    HorizontalOptions="Start" />
            </VerticalStackLayout>
        </Border>

        <RefreshView
            Grid.Row="3"
            Margin="10,5,10,5"
            BackgroundColor="Transparent">
            <CollectionView
                ItemsSource="{Binding Items}"
                SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10">
                            <Border
                                StrokeThickness="1"
                                Stroke="LightGray"
                                BackgroundColor="#DC3545"
                                HorizontalOptions="Fill">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Padding>
                                    <Thickness>16</Thickness>
                                </Border.Padding>
                                <Label
                                    Text="{Binding .}"
                                    TextColor="White"
                                    FontSize="18"
                                    HeightRequest="80"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>

    <!-- FIXED SCENARIO - With MaximumHeightRequest workaround -->
    <Grid
        Padding="0"
        BackgroundColor="Transparent"
        HorizontalOptions="Fill"
        RowDefinitions="Auto,Auto,Auto,*"
        VerticalOptions="Fill"
        IsVisible="{Binding ShowWorkaround}">
        <HorizontalStackLayout
            Grid.Row="0"
            HorizontalOptions="Center"
            Margin="0,10,0,10">
            <Label
                Text="✅ FIXED: Works Smoothly"
                FontSize="20"
                FontAttributes="Bold"
                TextColor="#28A745" />
        </HorizontalStackLayout>

        <VerticalStackLayout
            Grid.Row="1"
            Margin="10,0,10,10"
            Spacing="5">
            <Label
                Text="WORKAROUND APPLIED:"
                FontAttributes="Bold" />
            <Label
                Text="✓ Filter section wrapped with MaximumHeightRequest" />
            <Label
                Text="✓ ScrollView allows scrolling within constraint" />
            <Label
                Text="✓ Bottom sheet drags smoothly without freezing" />
            <Label
                Text=""
                Margin="0,10,0,0" />
            <Label
                Text="Drag the sheet down - it works perfectly!"
                FontAttributes="Italic"
                FontSize="12" />
        </VerticalStackLayout>

        <Border
            Grid.Row="2"
            MaximumHeightRequest="300"
            Margin="10,5,10,10"
            Padding="10"
            StrokeThickness="1"
            Stroke="LightGray"
            BackgroundColor="#F8F9FA">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <ScrollView>
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Column="0"
                            Text="Filter Options"
                            FontSize="16"
                            FontAttributes="Bold"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Text="✕"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            Padding="0"
                            HeightRequest="40"
                            WidthRequest="40" />
                    </Grid>

                    <FlexLayout
                        Wrap="Wrap"
                        Direction="Row"
                        JustifyContent="Start"
                        AlignItems="Start">
                        <Button Text="Filter 1" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#28A745" TextColor="White" />
                        <Button Text="Filter 2" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#28A745" TextColor="White" />
                        <Button Text="Filter 3" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#28A745" TextColor="White" />
                        <Button Text="Filter 4" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#28A745" TextColor="White" />
                        <Button Text="Filter 5" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#28A745" TextColor="White" />
                        <Button Text="Filter 6" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#28A745" TextColor="White" />
                        <Button Text="Filter 7" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#28A745" TextColor="White" />
                        <Button Text="Filter 8" Margin="4,2" Padding="12,8" FontSize="14" CornerRadius="20" BackgroundColor="#28A745" TextColor="White" />
                    </FlexLayout>

                    <Button
                        Text="Clear All"
                        FontSize="12"
                        Padding="8,4"
                        Margin="0,10,0,0"
                        BackgroundColor="Transparent"
                        TextColor="#28A745"
                        BorderColor="#28A745"
                        BorderWidth="1"
                        CornerRadius="12"
                        HorizontalOptions="Start" />
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <RefreshView
            Grid.Row="3"
            Margin="10,5,10,5"
            BackgroundColor="Transparent">
            <CollectionView
                ItemsSource="{Binding Items}"
                SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10">
                            <Border
                                StrokeThickness="1"
                                Stroke="LightGray"
                                BackgroundColor="#28A745"
                                HorizontalOptions="Fill">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.Padding>
                                    <Thickness>16</Thickness>
                                </Border.Padding>
                                <Label
                                    Text="{Binding .}"
                                    TextColor="White"
                                    FontSize="18"
                                    HeightRequest="80"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
    </Grid>
</ContentView>
