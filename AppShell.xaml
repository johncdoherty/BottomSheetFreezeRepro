    xmlns:local="clr-namespace:BottomSheetFreezeRepro"
    Title="BottomSheetFreezeRepro">

    <TabBar>
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage"
            Icon="{FontImage Glyph='🏠', Size=20}" />
        
