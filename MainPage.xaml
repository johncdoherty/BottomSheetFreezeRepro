<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:bottomSheet="clr-namespace:Syncfusion.Maui.Toolkit.BottomSheet;assembly=Syncfusion.Maui.Toolkit"
             xmlns:local="clr-namespace:BottomSheetFreezeRepro.ContentViews"
             xmlns:viewmodel="clr-namespace:BottomSheetFreezeRepro.ViewModels"
             x:Class="BottomSheetFreezeRepro.MainPage"
             x:DataType="viewmodel:MainViewModel"
             SafeAreaEdges="None">

    <Grid SafeAreaEdges="None">
        <VerticalStackLayout
            Padding="16"
            Spacing="12">
            <Label
                FontSize="20"
                FontAttributes="Bold"
                Text="Bottom Sheet Freeze Repro" />
            <Label
                Text="iOS 18.2+ with Tab Bar" 
                FontSize="16"/>
            <Label
                Text="REPRO STEPS:" 
                FontAttributes="Bold"
                Margin="0,10,0,0"/>
            <Label
                Text="1. Open the bottom sheet (tap button below)"/>
            <Label
                Text="2. Slowly drag the sheet downward to close"/>
            <Label
                Text="3. Observe: App freezes when the grabber handle reaches the bottom tab bar area"
                FontAttributes="Bold"/>
            <Label
                Text="Note: Freeze occurs at grabber position, not content position"
                FontSize="12"
                Margin="0,10,0,0"/>
            <Button
                Text="{Binding ScenarioButtonText}"
                Command="{Binding ToggleScenarioCommand}"
                Margin="0,10,0,0"
                FontAttributes="Bold" />
            <Button
                Text="Open bottom sheet"
                Clicked="OnOpenBottomSheetClicked" />
        </VerticalStackLayout>

        <bottomSheet:SfBottomSheet
            x:Name="ReproBottomSheet"
            Grid.Row="0"
            IsOpen="False"
            IsModal="True"
            AllowedState="FullExpanded"
            CollapseOnOverlayTap="True"
            CornerRadius="20"
            ContentPadding="16,8,16,16"
            FullExpandedRatio="0.9"
            HalfExpandedRatio="0.5"
            CollapsedHeight="0"
            State="FullExpanded">
            <bottomSheet:SfBottomSheet.BottomSheetContent>
                <local:ReproFeatureIdentifyContentView />
            </bottomSheet:SfBottomSheet.BottomSheetContent>
        </bottomSheet:SfBottomSheet>
    </Grid>

</ContentPage>
