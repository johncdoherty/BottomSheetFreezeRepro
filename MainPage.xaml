<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:bottomSheet="clr-namespace:Syncfusion.Maui.Toolkit.BottomSheet;assembly=Syncfusion.Maui.Toolkit"
             xmlns:local="clr-namespace:BottomSheetFreezeRepro.ContentViews"
             xmlns:viewmodel="clr-namespace:BottomSheetFreezeRepro.ViewModels"
             x:Class="BottomSheetFreezeRepro.MainPage"
             x:DataType="viewmodel:MainViewModel"
             SafeAreaEdges="None">

    <Grid SafeAreaEdges="None">
        <VerticalStackLayout
            Padding="16"
            Spacing="12">
            <Label
                FontSize="20"
                FontAttributes="Bold"
                Text="Bottom Sheet Freeze Repro" />
            <Label
                Text="iOS + Tab Bar" 
                FontSize="16"/>
            <Label
                Text="ISSUE:" 
                FontAttributes="Bold"
                Margin="0,10,0,0"/>
            <Label
                Text="Syncfusion SfBottomSheet freezes when grabber handle reaches tab bar zone"/>
            <Label
                Text="FINDINGS:" 
                FontAttributes="Bold"
                Margin="0,10,0,0"/>
            <Label
                Text="✅ Pure MAUI works perfectly"/>
            <Label
                Text="❌ Syncfusion freezes on drag"/>
            <Label
                Text="✅ Workaround: ScrollView + MaximumHeightRequest"/>
            <Button
                Text="{Binding DemoTypeButtonText}"
                Command="{Binding ToggleDemoTypeCommand}"
                Margin="0,10,0,0"
                FontAttributes="Bold"
                BackgroundColor="#007ACC" />
            <Button
                Text="{Binding ScenarioButtonText}"
                Command="{Binding ToggleScenarioCommand}"
                Margin="0,5,0,0"
                FontAttributes="Bold"
                IsVisible="{Binding ShowSyncfusionToggle}" />
            <Button
                Text="Open bottom sheet"
                Clicked="OnOpenBottomSheetClicked" />
        </VerticalStackLayout>

        <!-- Syncfusion Bottom Sheet -->
        <bottomSheet:SfBottomSheet
            x:Name="ReproBottomSheet"
            Grid.Row="0"
            IsOpen="False"
            IsModal="True"
            AllowedState="FullExpanded"
            CollapseOnOverlayTap="True"
            CornerRadius="20"
            ContentPadding="16,8,16,16"
            FullExpandedRatio="0.9"
            HalfExpandedRatio="0.5"
            CollapsedHeight="0"
            State="FullExpanded">
            <bottomSheet:SfBottomSheet.BottomSheetContent>
                <local:ReproFeatureIdentifyContentView />
            </bottomSheet:SfBottomSheet.BottomSheetContent>
        </bottomSheet:SfBottomSheet>
        
        <!-- Pure MAUI Bottom Sheet -->
        <local:PureMauiBottomSheet x:Name="MauiBottomSheet" />
    </Grid>

</ContentPage>
